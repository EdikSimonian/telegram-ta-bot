# ── Telegram ──────────────────────────────────────────────────────────────
# From @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Random string to verify webhook requests. Generate with: openssl rand -hex 16
WEBHOOK_SECRET=

# ── LLM provider (OpenAI direct) ──────────────────────────────────────────
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-5.4-nano
# Optional secondary model for quiz generation; falls back to AI_MODEL
QUIZ_MODEL=

# ── Embeddings (OpenAI) ───────────────────────────────────────────────────
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_MODEL=text-embedding-3-small

# ── Upstash Redis (required for TA bot — stateful) ────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Upstash Vector (RAG) ──────────────────────────────────────────────────
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# ── Upstash QStash (delayed quiz auto-reveal) ─────────────────────────────
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ── Vercel Blob (course doc storage) ──────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ── Bot identity / policy ─────────────────────────────────────────────────
PERMANENT_ADMIN=ediksimonian
# Per-student question limit in a rolling window
TA_RATE_LIMIT=10
TA_RATE_LIMIT_WINDOW=3600
# Existing daily hard cap (legacy)
RATE_LIMIT=250
QUIZ_TIMEOUT_MINUTES=3

# ── Deployment ────────────────────────────────────────────────────────────
# Public URL of this Vercel deployment. Used to build QStash callback URLs
# and by `make push` to register the Telegram webhook.
PROD_URL=
# Vercel auto-populates VERCEL_URL at runtime on preview/prod; set here only
# when testing QStash callbacks against a tunnel locally.
VERCEL_URL=

# ── Optional ──────────────────────────────────────────────────────────────
# Tavily web search (used only when RAG retrieval has no hits)
# TAVILY_API_KEY=
# HF Gradio fallback provider
# HF_SPACE_ID=
# HF_TOKEN=
