{
  "version": 2,
  "rewrites": [
    { "source": "/api/webhook", "destination": "/api/index" },
    { "source": "/api/health", "destination": "/api/index" },
    { "source": "/api/notify-admin", "destination": "/api/index" },
    { "source": "/api/git-sync-batch", "destination": "/api/git_sync_batch" }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "runtime": "@vercel/python@4.3.0"
    },
    "api/autoreveal.py": {
      "maxDuration": 30,
      "runtime": "@vercel/python@4.3.0"
    },
    "api/github.py": {
      "maxDuration": 60,
      "runtime": "@vercel/python@4.3.0"
    },
    "api/git_sync_batch.py": {
      "maxDuration": 60,
      "runtime": "@vercel/python@4.3.0"
    }
  }
}
