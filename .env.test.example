# Test environment — copy to .env.test and fill in.
# `make push-test` / `make deploy-test` read from this file.

BOT_ENV=test

# ── Telegram (@JohnWatsonTest_Bot)
TELEGRAM_BOT_TOKEN=
WEBHOOK_SECRET=

# ── LLM (OpenAI direct)
AI_API_KEY=
AI_MODEL=gpt-5.4-nano
QUIZ_MODEL=gpt-5.4-nano
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_MODEL=text-embedding-3-small

# ── Upstash Redis (shared DB; prefix isolates test keys) ──────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_PREFIX=ta:test:

# ── Upstash Vector (shared index; namespace isolates test vectors) ────────
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=
VECTOR_NAMESPACE=test

# ── Upstash QStash (region-scoped publish URL from console)
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ── Vercel Blob (auto-injected; do not set here)
# BLOB_READ_WRITE_TOKEN is auto-injected by Vercel when you connect the
# Blob store to this project. Leave it unset here. For local run_local.py
# use, pull via: vercel env pull .env.local
BLOB_PATH_PREFIX=docs/test/

# ── Bot policy
PERMANENT_ADMIN=ediksimonian
INSTRUCTOR_NAME=Edik Simonian
TA_RATE_LIMIT=10
TA_RATE_LIMIT_WINDOW=3600
QUIZ_TIMEOUT_MINUTES=5

# ── Vercel project targeting
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

PROD_URL=
